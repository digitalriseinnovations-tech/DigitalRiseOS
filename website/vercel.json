{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/agents/widget/widget.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=60" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/config/:slug", "destination": "/api/config" },
    { "source": "/agents/businesses/:slug/agents/:agentId", "destination": "/agents/businesses/agent-detail" },
    { "source": "/agents/businesses/:slug/agents", "destination": "/agents/businesses/agents" },
    { "source": "/agents/businesses/:slug/knowledge-base", "destination": "/agents/businesses/knowledge-base" },
    { "source": "/agents/businesses/:slug/conversations", "destination": "/agents/businesses/conversations" },
    { "source": "/agents/businesses/:slug/leads", "destination": "/agents/businesses/leads" },
    { "source": "/agents/businesses/:slug/bookings", "destination": "/agents/businesses/bookings" },
    { "source": "/agents/businesses/:slug/reviews", "destination": "/agents/businesses/reviews" },
    { "source": "/agents/businesses/:slug/deploy", "destination": "/agents/businesses/deploy" },
    { "source": "/agents/businesses/:slug", "destination": "/agents/businesses/detail" }
  ]
}
